DATABASE_URL=postgresql+asyncpg://crudemap:crudemap@localhost:5432/crudemap
ETL_LOADER=json
# Optional: free key from https://aisstream.io/apikeys — enables live AIS tankers.
# Without it, the app runs with simulated traffic only.
AISSTREAM_API_KEY=
